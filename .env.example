# =============================================================================
# OpenClaw + NemoClaw — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# IMPORTANT:
#   - .env is gitignored — it will never be committed
#   - Never put real secrets in this .example file
#   - Run scripts/validate-env.sh before starting to catch placeholder values
#   - Inference provider credentials are managed by NemoClaw via the onboard
#     wizard; the API keys here are optional pre-seeds for that wizard.
# =============================================================================

# --- NemoClaw Sandbox ---
# Name used to identify the sandbox in 'nemoclaw list' output.
NEMOCLAW_SANDBOX_NAME=openclaw

# Optional: override NemoClaw port bindings (defaults shown)
# NEMOCLAW_GATEWAY_PORT=18789
# NEMOCLAW_DASHBOARD_PORT=18790
# NEMOCLAW_OLLAMA_PORT=11434

# Timezone
OPENCLAW_TZ=UTC

# --- Non-interactive Onboard (optional) ---
# Set NEMOCLAW_NON_INTERACTIVE=1 to skip the wizard entirely and drive onboard
# from env vars below. Also set NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1.
# NEMOCLAW_NON_INTERACTIVE=1
# NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
# NEMOCLAW_POLICY_TIER=balanced        # restricted | balanced | open

# --- LLM Provider API Keys (pre-seeds for the onboard wizard) ---
# The onboard wizard will prompt for credentials; setting these here means
# you won't be asked interactively. Also required for non-interactive onboard.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY

# OpenAI
# OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY

# OpenRouter (routes to many providers)
# OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# Ollama (local/self-hosted — no API key required)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Messaging Channel Tokens (optional) ---
# NemoClaw forwards these to the sandbox for Telegram/Discord integration.

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_TOKEN

# Comma-separated list of Telegram user IDs allowed to message the bot
# TELEGRAM_ALLOWED_IDS=

# Discord bot token
# DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_TOKEN

# --- OpenClaw Directories ---
# NemoClaw snapshots ~/.openclaw/openclaw.json during onboard.
# Keep these outside the repo.
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace