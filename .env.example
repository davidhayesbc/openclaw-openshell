# =============================================================================
# OpenClaw + OpenShell — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# IMPORTANT:
#   - .env is gitignored — it will never be committed
#   - Never put real secrets in this .example file
#   - Run `scripts/validate-env.sh` before starting to catch placeholder values
#   - Use `scripts/rotate-token.sh` to safely rotate the gateway token
# =============================================================================

# --- OpenClaw Gateway ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# Bind address: "loopback" (localhost only) or "lan" (network-accessible)
# Prefer loopback unless you need remote access. If using LAN, also set up
# the reverse proxy documented in docs/security.md.
OPENCLAW_GATEWAY_BIND=loopback

# Port (default 18789 — change if it conflicts)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Timezone
OPENCLAW_TZ=UTC

# --- LLM Provider API Keys (provide at least one) ---
# Anthropic (Claude)
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY

# OpenRouter (alternative — can route to many providers)
# OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# Ollama (local/self-hosted)
# For local-only setups, this can be any non-empty value.
# OpenClaw uses this env var to enable the Ollama provider.
# OLLAMA_API_KEY=ollama-local

# Ollama API endpoint reachable from the HOST (used for model discovery at startup).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# URL the OpenShell sandbox uses to reach Ollama.
# OpenShell SSRF protection blocks direct host IPs; use the inference.local bypass:
OLLAMA_SANDBOX_URL=https://inference.local/v1

# Default model set on first gateway start (format: provider/model-id).
# After the first start the gateway preserves your UI model selection.
OLLAMA_DEFAULT_MODEL=ollama/qwen3:latest

# --- LM Studio (optional — local LLM with GPU acceleration) ---
# LM Studio provides OpenAI-compatible API with GPU support. Can run alongside Ollama.
# Download: https://lmstudio.ai
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_API_TOKEN=lm-studio (optional — most installs use no auth)

# --- Messaging Channel Tokens (optional — add what you use) ---
# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_TOKEN
# Your Telegram user ID — only this peer can DM the bot.
# Find it with: openclaw directory self --channel telegram
# TELEGRAM_ALLOWED_PEER=REPLACE_WITH_YOUR_TELEGRAM_USER_ID

# Discord bot token
# DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_TOKEN

# --- OpenClaw Directories ---
# These are mounted into the container. Keep these outside the repo.
# Absolute paths recommended on Linux/macOS; on Windows use WSL paths.
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace

# Optional: explicit path to agent workspaces source directory.
# If set, scripts/start.sh syncs <dir>/<agent-id>/workspace into
# ~/.openclaw/workspace-<agent-id> inside the sandbox.
# Examples:
#   OPENCLAW_AGENTS_DIR=${HOME}/src/agents
#   OPENCLAW_AGENTS_DIR=/mnt/e/src/agents
# OPENCLAW_AGENTS_DIR=

# --- Docker ---
# Uncomment and set to your docker group GID if enabling agent sandboxing
# (stat -c '%g' /var/run/docker.sock)
# DOCKER_GID=999

# --- OpenShell (if using the OpenShell sandbox path) ---
# OpenShell CLI version to pin — check https://github.com/NVIDIA/OpenShell/releases
OPENSHELL_VERSION=latest

# Name for the OpenClaw sandbox created by OpenShell
OPENSHELL_SANDBOX_NAME=openclaw
