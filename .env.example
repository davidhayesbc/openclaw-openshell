# =============================================================================
# OpenClaw + OpenShell — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# IMPORTANT:
#   - .env is gitignored — it will never be committed
#   - Never put real secrets in this .example file
#   - Run `scripts/validate-env.sh` before starting to catch placeholder values
#   - Use `scripts/rotate-token.sh` to safely rotate the gateway token
# =============================================================================

# --- OpenClaw Gateway ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# Bind address: "loopback" (localhost only) or "lan" (network-accessible)
# Prefer loopback unless you need remote access. If using LAN, also set up
# the reverse proxy documented in docs/security.md.
OPENCLAW_GATEWAY_BIND=loopback

# Port (default 18789 — change if it conflicts)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Timezone
OPENCLAW_TZ=UTC

# --- LLM Provider API Keys (provide at least one) ---
# Anthropic (Claude)
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY

# OpenRouter (alternative — can route to many providers)
# OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# --- Messaging Channel Tokens (optional — add what you use) ---
# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_TOKEN

# Discord bot token
# DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_TOKEN

# --- OpenClaw Directories ---
# These are mounted into the container. Keep these outside the repo.
# Absolute paths recommended on Linux/macOS; on Windows use WSL paths.
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace

# --- Docker ---
# Uncomment and set to your docker group GID if enabling agent sandboxing
# (stat -c '%g' /var/run/docker.sock)
# DOCKER_GID=999

# --- OpenShell (if using the OpenShell sandbox path) ---
# OpenShell CLI version to pin — check https://github.com/NVIDIA/OpenShell/releases
OPENSHELL_VERSION=latest

# Name for the OpenClaw sandbox created by OpenShell
OPENSHELL_SANDBOX_NAME=openclaw
