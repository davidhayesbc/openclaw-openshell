{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": { "mode": "token" },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },

  "tools": {
    "profile": "messaging",
    "deny": [
      "group:automation",
      "group:runtime",
      "group:fs",
      "sessions_spawn",
      "sessions_send"
    ],

    "fs": {
      "workspaceOnly": true
    },

    "exec": {
      "security": "deny",
      "ask": "always"
    },

    "elevated": {
      "enabled": false
    }
  },

  "logging": {
    "redactSensitive": "tools",
    "level": "info"
  },

  "agents": {
    "defaults": {},
    // Add entries here for each additional agent you create.
    // Each agent gets its own workspace, session history, and auth profiles.
    // The first entry (or the one with "default": true) is the fallback agent.
    // "list": [
    //   { "id": "main",  "workspace": "~/.openclaw/workspace" },
    //   { "id": "coder", "workspace": "~/.openclaw/workspace-coder" }
    // ]
  },

  // Bindings route inbound messages to specific agents.
  // Most-specific match wins (peer > channel > fallback).
  // Omit this block to send all traffic to the default agent.
  // "bindings": [
  //   {
  //     "agentId": "coder",
  //     "match": {
  //       "channel": "telegram",
  //       "peer": { "kind": "direct", "id": "YOUR_TELEGRAM_USER_ID" }
  //     }
  //   }
  // ],

  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      // After pairing, add your numeric Telegram user ID here to allow
      // both DMs and group messages. Find it in: openclaw logs | grep from.id
      // "allowFrom": ["YOUR_TELEGRAM_USER_ID"],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  }
}
